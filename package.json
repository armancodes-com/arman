    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8",
